# PhaseAI Dashboard - Environment Variables Template
# Copy this file to .env.local for local development
# Add these variables to your Vercel Project Settings for production

# ─── API Configuration ───────────────────────────────────────────
# The base URL of your FastAPI backend (Render or Local)
NEXT_PUBLIC_API_URL=https://os-ai.onrender.com

# (Optional) Websocket URL if you plan to implement real-time streaming
# NEXT_PUBLIC_WS_URL=wss://os-ai.onrender.com/ws

# ─── Application Settings ─────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="PhaseAI Business OS"
NEXT_PUBLIC_ENVIRONMENT=production
